{
  "info": {
    "name": "Employee Management System API",
    "description": "Sample corporate-style REST API for managing departments and employees. Import this collection and the {{baseUrl}} variable into Postman, then run requests top to bottom (create a department first, then employees referencing it).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1" },
    { "key": "departmentId", "value": "1" },
    { "key": "employeeId", "value": "1" }
  ],
  "item": [
    {
      "name": "Departments",
      "item": [
        {
          "name": "Create Department",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/departments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Engineering\",\n  \"code\": \"ENG\",\n  \"description\": \"Builds and maintains the product\"\n}"
            }
          }
        },
        {
          "name": "Get All Departments",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/departments"
          }
        },
        {
          "name": "Get Department By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/departments/{{departmentId}}"
          }
        },
        {
          "name": "Update Department",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/departments/{{departmentId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Engineering\",\n  \"code\": \"ENG\",\n  \"description\": \"Builds, ships and operates the product\"\n}"
            }
          }
        },
        {
          "name": "Delete Department",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/departments/{{departmentId}}"
          }
        }
      ]
    },
    {
      "name": "Employees",
      "item": [
        {
          "name": "Create Employee",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/employees",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Ada\",\n  \"lastName\": \"Lovelace\",\n  \"email\": \"ada.lovelace@example.com\",\n  \"phoneNumber\": \"+15551234567\",\n  \"designation\": \"Principal Engineer\",\n  \"salary\": 125000.00,\n  \"dateOfJoining\": \"2024-01-15\",\n  \"departmentId\": {{departmentId}}\n}"
            }
          }
        },
        {
          "name": "Get Employee By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/employees/{{employeeId}}"
          }
        },
        {
          "name": "Search/List Employees (paginated)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/employees?page=0&size=10&sort=lastName,asc",
              "host": ["{{baseUrl}}"],
              "path": ["employees"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "sort", "value": "lastName,asc" }
              ]
            }
          }
        },
        {
          "name": "Filter Employees by Department + Active + Search",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/employees?departmentId={{departmentId}}&active=true&search=ada",
              "host": ["{{baseUrl}}"],
              "path": ["employees"],
              "query": [
                { "key": "departmentId", "value": "{{departmentId}}" },
                { "key": "active", "value": "true" },
                { "key": "search", "value": "ada" }
              ]
            }
          }
        },
        {
          "name": "Update Employee",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/employees/{{employeeId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Ada\",\n  \"lastName\": \"Lovelace\",\n  \"email\": \"ada.lovelace@example.com\",\n  \"phoneNumber\": \"+15551234567\",\n  \"designation\": \"Distinguished Engineer\",\n  \"salary\": 145000.00,\n  \"dateOfJoining\": \"2024-01-15\",\n  \"departmentId\": {{departmentId}}\n}"
            }
          }
        },
        {
          "name": "Update Employee Status (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/employees/{{employeeId}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"active\": false\n}"
            }
          }
        },
        {
          "name": "Delete Employee",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/employees/{{employeeId}}"
          }
        }
      ]
    },
    {
      "name": "Ops",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "http://localhost:8080/actuator/health"
          }
        }
      ]
    }
  ]
}
